# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv virtual environment (lazily created by `uv sync`)
.venv/

# Transient operation dirs (lazily created)
.tmp/
.tools/

# Runtime MCP configs carry tokens; the *.example templates stay committed.
.mcp.json
.cursor/mcp.json

# User content (per spec)
projects/
tasks/
solaris/spec/references/

# Plugins are user-private overlays: ignore everything except the committed placeholder.
plugins/*
!plugins/.empty

# Framework-level secrets + runtime log
memory/*
!memory/.empty

# Claude Code: keep project settings tracked, ignore per-user local overrides
.claude/settings.local.json
